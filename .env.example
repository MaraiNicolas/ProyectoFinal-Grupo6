# Plantilla de variables de entorno para Docker Compose.
#
# INSTRUCCIONES:
#   1. Copiar este archivo a ".env" en la misma carpeta que docker-compose.yml.
#   2. Completar los valores reales segun el entorno (dev / staging / prod).
#   3. NO commitear el archivo ".env" - solo este ".env.example".
#
# Docker Compose lee ".env" automaticamente y reemplaza ${VAR} en docker-compose.yml.


# ============================================================================
# SSO Finnegans
# ============================================================================

# Habilita el endpoint GET /api/auth/sso. Si esta en "false" responde 404.
FINNEGANS_ENABLED=false

# URL base de la API de Finnegans (sin slash al final).
# Pedir el valor al cliente. Ej: https://servicios.cliente.com
BASE_GO_URL=<COMPLETAR-CON-URL-DE-API-FINNEGANS>

# Path del endpoint de validacion de tokens.
FINNEGANS_INVITADOS_ENDPOINT=/api/1/invitados

# Si esta en "true", crea el Usuario automaticamente en su primer login SSO.
# Si esta en "false", el usuario debe existir previamente en la base de datos.
FINNEGANS_AUTO_CREATE=false

# Rol asignado a usuarios autocreados que no son admin en Finnegans.
FINNEGANS_ROL_DEFAULT=Empleado


# ============================================================================
# JWT (firma de los tokens propios)
# ============================================================================

# CRITICO: generar una clave nueva, NO usar el placeholder.
# Comando recomendado: openssl rand -base64 48
JWT_KEY=<GENERAR-CLAVE-SECRETA-MINIMO-32-CHARS>

JWT_ISSUER=ProyectoFinalGrupo6
JWT_AUDIENCE=ProyectoFinalGrupo6Clients


# ============================================================================
# Servicios externos
# ============================================================================

# HikCentral: "true" usa mock, "false" requiere VPN + credenciales reales.
HIKCENTRAL_USE_MOCK=true

# Auditoria: "true" guarda en memoria, "false" requiere DynamoDB.
AUDIT_USE_MOCK=true

# Email: "true" logea a consola, "false" requiere config SMTP.
EMAIL_USE_MOCK=true


# ============================================================================
# Frontend
# ============================================================================

# URL del backend desde la perspectiva del navegador del usuario.
# Vite la inlinea en el bundle durante "npm run build".
# Para cambiarla hay que rebuildear la imagen: docker compose up -d --build frontend
VITE_API_URL=http://localhost:8080/api
